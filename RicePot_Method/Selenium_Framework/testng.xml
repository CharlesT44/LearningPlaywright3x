<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Salesforce Login Suite" parallel="false">
    <parameter name="validUsername" value="your-email@example.com"/>
    <parameter name="validPassword" value="your-password"/>

    <test name="Invalid Login Tests" preserve-order="true">
        <classes>
            <class name="com.enterprise.sf.tests.LoginTest_Invalid"/>
        </classes>
    </test>

    <test name="Valid Login Test" preserve-order="true">
        <classes>
            <class name="com.enterprise.sf.tests.LoginTest_Valid"/>
        </classes>
    </test>
</suite>
